# Practical 10: Generate text using a character-based model using an appropriate dataset.
# Given a sequence of characters from a given data (eg "Shakespear"), train a model to predict the next character in the sequence ("e").

import numpy as np
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense
from tensorflow.keras.utils import to_categorical

def text_generation_pipeline():
    print("=== Character-Based Text Generation (LSTM) ===")
    
    # 1. Input Choice
    choice = input("Do you want to use the default 'Shakespeare' text? (y/n): ").strip().lower()
    
    if choice == 'n':
        raw_text = input("Enter a string of text to train on (longer is better): ")
    else:
        # A small snippet of Shakespeare-style text for demonstration
        raw_text = "to be or not to be that is the question whether tis nobler in the mind to suffer"
        print(f"\n[Using Default Text]: '{raw_text}'")

    # 2. Map characters to integers
    chars = sorted(list(set(raw_text)))
    char_to_int = {c: i for i, c in enumerate(chars)}
    int_to_char = {i: c for i, c in enumerate(chars)}
    
    n_chars = len(raw_text)
    n_vocab = len(chars)
    
    # 3. Prepare the dataset (Windowing)
    seq_length = 5  # Length of the input sequence
    X_data = []
    y_data = []
    
    for i in range(0, n_chars - seq_length):
        seq_in = raw_text[i:i + seq_length]
        seq_out = raw_text[i + seq_length]
        X_data.append([char_to_int[char] for char in seq_in])
        y_data.append(char_to_int[seq_out])
        
    n_patterns = len(X_data)
    
    # Reshape X to [samples, time steps, features] and normalize
    X = np.reshape(X_data, (n_patterns, seq_length, 1))
    X = X / float(n_vocab)
    
    # One-hot encode the output variable
    y = to_categorical(y_data)

    # 4. Build the LSTM Model
    print(f"\nTraining model on {n_patterns} sequences... (This will take a few seconds)")
    model = Sequential([
        LSTM(128, input_shape=(X.shape[1], X.shape[2])),
        Dense(y.shape[1], activation='softmax')
    ])
    
    model.compile(loss='categorical_crossentropy', optimizer='adam')
    
    # Train the model (Keep epochs low for a fast exam demo)
    model.fit(X, y, epochs=100, verbose=0)
    print("Training Complete!")

    # 5. Generate Text
    seed = raw_text[:seq_length]
    generated_text = seed
    
    print(f"\nSeed text: '{seed}'")
    print("Generating next 10 characters...")

    for i in range(15):
        # Format the seed for prediction
        x_input = np.reshape([char_to_int[c] for c in seed], (1, len(seed), 1))
        x_input = x_input / float(n_vocab)
        
        # Predict probabilities
        prediction = model.predict(x_input, verbose=0)
        index = np.argmax(prediction)
        result = int_to_char[index]
        
        generated_text += result
        # Slide the window: remove the first char, add the new predicted char
        seed = seed[1:] + result

    print(f"\nFinal Generated Sequence: '{generated_text}'")

if __name__ == "__main__":
    text_generation_pipeline()
